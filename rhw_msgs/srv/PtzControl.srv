# 服务: /ptz/control
# 云台方向控制、变倍、停止

# 方向: left/right/up/down/leftup/rightup/leftdown/rightdown/zoomin/zoomout/stop
string direction

# 速度 1-100
uint8 speed

# 通道号，默认 1
uint8 channel

# 持续时间(毫秒)，0 表示持续到手动 stop
uint32 duration_ms

---

# 0 失败 1 成功
int8 result

# single / timed_auto_stop / continuous_until_manual_stop
string execution_mode

# 结果说明
string message
